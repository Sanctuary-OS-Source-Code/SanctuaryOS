{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sanctuary OS",
  "version": "0.1.0",
  "identifier": "sanctuary-os-V1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "width": 1366,
        "height": 768,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "center": true,
        "title": "Sanctuary OS",
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Sanctuary-OS-Source-Code/sanctuary-os/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE1RkY0NzgxM0UxM0VFQjcKUldTMzdoTStnVWYvcFVWUStUSnltUWFtT2FZaTBGT1JUSnV6MHNSSnBpRlBUTDdNckw3QzNmeXIK"
    }
  }
}